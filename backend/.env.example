# App
ENVIRONMENT=development
DEBUG=true

# Supabase Postgres connection string
# Find this in Supabase Dashboard > Project Settings > Database > Connection String (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - comma separated frontend URLs allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173,https://ishdigitalstudio.com

# Admin bootstrap (used by seed script to create the first admin login)
ADMIN_EMAIL=ishwardhakad779@gmail.com
ADMIN_INITIAL_PASSWORD=replace-with-a-strong-password

# SMTP (for contact/consultation email notifications)
# Example using Gmail: enable an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=no-reply@ishdigitalstudio.com
ADMIN_NOTIFICATION_EMAIL=ishwardhakad779@gmail.com
